      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              " const json = pm.response.json();    ",
              "",
              "pm.test(\"Response should be an array\",  () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "})",
              "",
              "pm.test(\"Content-type header should exist\",  () => {",
              "    pm.expect(pm.response.headers.get('Content-type')).to.include('application/json');",
              "    pm.response.to.have.header('Content-type'); ",
              "})",
              "",
              "pm.test('element should have title containing Generic', () => {",
              "    const sleekItem = json.find(item => item.title && item.title.includes('Generic'));",
              "    pm.expect(sleekItem).to.not.be.undefined;",
              "    pm.expect(sleekItem.title).to.include('Generic');",
              "});",
              "",
              "",
              "pm.test('every element contain title = \"Generic\"', ()=>{",
              "  //  for (let i = 0; i < json.length; i++) {",
              "  //      pm.expect(json[i].title).to.include('Sleek');",
              "//}",
              "for (const product of json) {",
              "    pm.expect(product.title).to.include('Generic');",
              "}",
              "});",
              "",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
